---
import Layout from "../layouts/Layout.astro";
import Socials from "../components/Socials.astro";
import { Image } from "astro:assets";
import profileImage from "../assets/profile.jpg";
---

<Layout title="Berken Tekin">
	<div
		class="flex flex-col items-center justify-center min-h-[60vh] text-center"
	>
		<Image
			src={profileImage}
			alt="Berken Tekin"
			class="w-48 h-48 rounded-full object-cover shadow-lg mb-8 mx-auto"
			width={384}
			densities={[1.5, 2]}
		/>
		{
			/*
		<h1
			class="text-2xl md:text-3xl font-serif font-normal italic mt-4 text-gray-600 tracking-normal"
		>
			One person among billions
		</h1>
	    */
		}
		<div
			class="max-w-2xl mx-auto px-4 font-serif text-lg md:text-xl leading-relaxed text-gray-800 dark:text-gray-200"
		>
			<p>
				Welcome to my page. Here I publish my <a
					href="/personal"
					class="underline decoration-1 underline-offset-4 hover:text-gray-600"
					>stories and essays</a
				>, and showcase my <a
					href="/professional"
					class="underline decoration-1 underline-offset-4 hover:text-gray-600"
					>professional work</a
				>.
			</p>
		</div>

		<div class="mt-12">
			<Socials />
		</div>
	</div>
</Layout>

<script>
	const prefetchPDF = async () => {
		const url = "/cv.pdf";
		try {
			// Check if already prefetched/cached (simple check)
			// Using fetch with low priority to populate browser cache
			await fetch(url, { priority: "low" });
		} catch (e) {
			// Fail silently
		}
	};

	const preconnectToOrigin = (urlStr: string) => {
		try {
			const url = new URL(urlStr);
			const origin = url.origin;
			if (
				!document.querySelector(
					`link[rel="preconnect"][href="${origin}"]`,
				)
			) {
				const link = document.createElement("link");
				link.rel = "preconnect";
				link.href = origin;
				link.crossOrigin = "anonymous";
				document.head.appendChild(link);
			}
		} catch (e) {
			// Fail silently for invalid URLs
		}
	};

	const setupPrefetch = () => {
		// PDF Prefetch
		const professionalLinks = document.querySelectorAll(
			'a[href="/professional"]',
		);
		if (professionalLinks.length > 0) {
			professionalLinks.forEach((link) => {
				link.addEventListener("mouseenter", prefetchPDF, {
					once: true,
				});
			});
		}

		// Socials Preconnect
		const socialLinks = document.querySelectorAll(
			'a[aria-label="GitHub"], a[aria-label="LinkedIn"], a[aria-label="Instagram"]',
		);
		if (socialLinks.length > 0) {
			socialLinks.forEach((link) => {
				const href = link.getAttribute("href");
				if (href) {
					link.addEventListener(
						"mouseenter",
						() => preconnectToOrigin(href),
						{ once: true },
					);
				}
			});
		}
	};

	document.addEventListener("astro:page-load", setupPrefetch);
	// Handle initial load
	setupPrefetch();
</script>
